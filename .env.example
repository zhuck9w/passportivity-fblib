SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_PUBLISHABLE_KEY=your-publishable-key

# Recommended for backend writes. Keep this server-only.
SUPABASE_SECRET_KEY=your-secret-or-service-role-key
# Also supported for your current local setup:
# SECRET=your-secret-or-service-role-key

PORT=4000
SCRAPER_HEADLESS=false
SCRAPER_SLOW_MO_MS=250
SCRAPER_LIMIT=25
SCRAPER_MAX_ADS=25
SCRAPER_MAX_SCROLLS=12
