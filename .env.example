SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_PUBLISHABLE_KEY=your-publishable-key

# Recommended for backend writes. Keep this server-only.
SUPABASE_SECRET_KEY=your-secret-or-service-role-key
# Also supported for your current local setup:
# SECRET=your-secret-or-service-role-key

# Interface backend port (competitors / ads / geo). Served to the frontend.
PORT=4000
# Scraper service port (start/stop/status of scraping + Playwright).
SCRAPER_PORT=4001

# --- Frontend (Vite, optional in local dev) ---
# Interface backend base URL. Empty = same-origin (dev proxy / Vercel). Leave unset for local dev.
# VITE_API_URL=
# Scraper service base URL. Defaults to http://localhost:4001 in dev; set this when the
# scraper lives on another host.
# VITE_SCRAPER_URL=http://localhost:4001

SCRAPER_HEADLESS=false
SCRAPER_BROWSER_CHANNEL=chrome
SCRAPER_USER_DATA_DIR=.playwright-profile
SCRAPER_SLOW_MO_MS=250
SCRAPER_LIMIT=25
SCRAPER_MAX_ADS=25
SCRAPER_MAX_SCROLLS=12
SCRAPER_COLLECT_CAROUSELS=true
