{
  "name": "ad-library-search",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently -n interface,scraper,client -c blue,magenta,green \"npm:dev:interface\" \"npm:dev:scraper\" \"npm:dev:client\"",
    "dev:backend": "concurrently -n interface,scraper -c blue,magenta \"npm:dev:interface\" \"npm:dev:scraper\"",
    "dev:interface": "tsx watch src/server/interface.ts",
    "dev:scraper": "tsx watch src/server/scraperService.ts",
    "dev:client": "vite --host 0.0.0.0",
    "build": "tsc --noEmit && vite build",
    "test": "vitest run",
    "login:facebook": "tsx src/server/scripts/loginFacebookProfile.ts",
    "restore:split-ads": "tsx src/server/scripts/restoreSplitAds.ts",
    "scrape": "tsx src/server/scripts/runScrape.ts"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.84.0",
    "cors": "^2.8.5",
    "dotenv": "^17.2.3",
    "express": "^5.2.1",
    "lucide-react": "^0.560.0",
    "playwright": "^1.57.0",
    "react": "^19.2.1",
    "react-dom": "^19.2.1",
    "zod": "^4.2.1"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node": "^25.0.2",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.2",
    "concurrently": "^9.2.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vite": "^7.2.7",
    "vitest": "^4.0.16"
  }
}
